# ========================================
#  SOL 二段监控系统 — 配置文件
#  复制为 .env 并填入你的 API 密钥
# ========================================

# ---- 必填: X (Twitter) API ----
X_BEARER_TOKEN=your_x_bearer_token_here

# ---- 必填: Birdeye API (付费) ----
BIRDEYE_API_KEY=your_birdeye_api_key_here

# ---- 可选: Helius API (备用数据源) ----
HELIUS_API_KEY=

# ---- Discord Webhook (热度暴涨通知) ----
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/1474357109666873457/zGiWxWk8QLW8VzXiK33I8qyznxhYw7koyRtV2VhtOAD6sndw0igdabIvCzorNID62PEo

# ---- 服务配置 ----
API_HOST=0.0.0.0
API_PORT=8888

# ---- DexScreener 筛选阈值 ----
MIN_AGE_HOURS=2
MIN_MCAP=200000
MIN_LIQUIDITY=50000
MIN_VOLUME=300000

# ---- 退出条件 ----
EXIT_FDV_THRESHOLD=50000
EXIT_AGE_HOURS=24
EXIT_LOW_HEAT_THRESHOLD=50
EXIT_LOW_HEAT_CONSECUTIVE=2

# ---- 热度通知阈值 ----
HEAT_SPIKE_PERCENT=50
HEAT_SPIKE_MIN_SCORE=200

# ---- 轮询间隔 (秒) ----
BIRDEYE_POLL_INTERVAL=30
X_HEAT_INTERVAL=900
DEXSCREENER_SCAN_INTERVAL=300
